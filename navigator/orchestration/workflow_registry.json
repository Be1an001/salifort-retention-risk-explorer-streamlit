        "RAG_STREAMLIT_OPENAI_API_KEY",
        "OPENAI_API_KEY"
      ],
      "required_artifacts": [
        "navigator/retrieval_pack/chunks.jsonl"
      ],
      "blocked_states": [
        "registry validation failure",
        "retrieval pack validation failure",
        "missing API key",
        "OpenAI embedding request failure"
      ],
      "scheduler_eligibility": "local_airflow_manual_or_dev_only",
      "human_review_required": true,
      "mutates_repo_files": true,
      "notes": "Builds retrieval artifacts and embedding index from governed registries; writes repo artifacts and should remain review-gated."
    },
